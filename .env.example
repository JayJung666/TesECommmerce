# API Configuration
API_BASE_URL=https://api.atlantisshop.com/v1

# Firebase Configuration (Get from Firebase Console)
FIREBASE_PROJECT_ID=atlantis-shop-prod
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Payment Gateways
MIDTRANS_CLIENT_KEY=SB-Mid-client-your_sandbox_client_key
MIDTRANS_SERVER_KEY=SB-Mid-server-your_sandbox_server_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Analytics & Monitoring
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
FIREBASE_ANALYTICS_ENABLED=true
FIREBASE_CRASHLYTICS_ENABLED=true

# App Configuration
APP_FLAVOR=dev
DEBUG_MODE=true
ENABLE_LOGGING=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/atlantisshop

# Email Service (Optional)
SENDGRID_API_KEY=your_sendgrid_api_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=atlantis-shop-assets

# Social Login
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id

# Notification Services
FCM_SERVER_KEY=your_fcm_server_key
ONESIGNAL_APP_ID=your_onesignal_app_id

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# Security
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters
BCRYPT_ROUNDS=12
CORS_ORIGIN=https://atlantisshop.com